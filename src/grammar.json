{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rux",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "operator"
          },
          {
            "type": "SYMBOL",
            "name": "bracket"
          },
          {
            "type": "SYMBOL",
            "name": "delimiter"
          },
          {
            "type": "SYMBOL",
            "name": "keyword"
          },
          {
            "type": "SYMBOL",
            "name": "number"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "SYMBOL",
            "name": "identifier"
          }
        ]
      }
    },
    "operator": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "!"
          },
          {
            "type": "STRING",
            "value": "'"
          },
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "STRING",
            "value": ">"
          },
          {
            "type": "STRING",
            "value": "+"
          },
          {
            "type": "STRING",
            "value": "-"
          },
          {
            "type": "STRING",
            "value": "*"
          },
          {
            "type": "STRING",
            "value": "/"
          },
          {
            "type": "STRING",
            "value": "%"
          },
          {
            "type": "STRING",
            "value": "·"
          },
          {
            "type": "STRING",
            "value": "^"
          },
          {
            "type": "STRING",
            "value": "|"
          },
          {
            "type": "STRING",
            "value": "&"
          },
          {
            "type": "STRING",
            "value": ":"
          }
        ]
      }
    },
    "open_round": {
      "type": "PATTERN",
      "value": "\\("
    },
    "open_squared": {
      "type": "PATTERN",
      "value": "\\["
    },
    "open_curly": {
      "type": "PATTERN",
      "value": "\\{"
    },
    "closed_round": {
      "type": "PATTERN",
      "value": "\\)"
    },
    "closed_squared": {
      "type": "PATTERN",
      "value": "\\]"
    },
    "closed_curly": {
      "type": "PATTERN",
      "value": "\\}"
    },
    "bracket": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "open_round"
        },
        {
          "type": "SYMBOL",
          "name": "open_squared"
        },
        {
          "type": "SYMBOL",
          "name": "open_curly"
        },
        {
          "type": "SYMBOL",
          "name": "closed_round"
        },
        {
          "type": "SYMBOL",
          "name": "closed_squared"
        },
        {
          "type": "SYMBOL",
          "name": "closed_curly"
        }
      ]
    },
    "delimiter": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "STRING",
            "value": ";"
          },
          {
            "type": "STRING",
            "value": ","
          }
        ]
      }
    },
    "keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "fn"
        },
        {
          "type": "STRING",
          "value": "struct"
        },
        {
          "type": "STRING",
          "value": "enum"
        },
        {
          "type": "STRING",
          "value": "let"
        },
        {
          "type": "STRING",
          "value": "var"
        },
        {
          "type": "STRING",
          "value": "if"
        },
        {
          "type": "STRING",
          "value": "else"
        },
        {
          "type": "STRING",
          "value": "loop"
        },
        {
          "type": "STRING",
          "value": "in"
        },
        {
          "type": "STRING",
          "value": "return"
        },
        {
          "type": "STRING",
          "value": "break"
        },
        {
          "type": "STRING",
          "value": "continue"
        }
      ]
    },
    "number": {
      "type": "PATTERN",
      "value": "\\d+\\.?\\d*\\w*"
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"\\\\]+"
                },
                {
                  "type": "PATTERN",
                  "value": "\\\\."
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "identifier": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier_upper_snake_case"
        },
        {
          "type": "SYMBOL",
          "name": "identifier_pascal_case"
        },
        {
          "type": "SYMBOL",
          "name": "identifier_snake_case"
        }
      ]
    },
    "identifier_snake_case": {
      "type": "PATTERN",
      "value": "[a-z][a-z0-9]*(?:_[a-z0-9]+)*"
    },
    "identifier_upper_snake_case": {
      "type": "PATTERN",
      "value": "[A-Z][A-Z0-9]*(?:_[A-Z0-9]+)*"
    },
    "identifier_pascal_case": {
      "type": "PATTERN",
      "value": "(?:[A-Z][a-zA-Z0-9]*|[a-z]+(?:[A-Z][a-zA-Z0-9]*)+)"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}
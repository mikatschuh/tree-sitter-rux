              "type": "PATTERN",
              "value": "(?:0b(?:_*[01](?:_*[01])*_*(?:\\._*[01](?:_*[01])*_*)?|_*\\._*[01](?:_*[01])*_*)(?:e[+-]?(?:_*[0-9](?:_*[0-9])*_*|0b_*[01](?:_*[01])*_*|0s_*[0-5](?:_*[0-5])*_*|0o_*[0-7](?:_*[0-7])*_*|0d_*[0-9AaBb](?:_*[0-9AaBb])*_*|0x_*[0-9A-Fa-f](?:_*[0-9A-Fa-f])*_*))?)"
            },
            {
              "type": "PATTERN",
              "value": "(?:0s(?:_*[0-5](?:_*[0-5])*_*(?:\\._*[0-5](?:_*[0-5])*_*)?|_*\\._*[0-5](?:_*[0-5])*_*))"
            },
            {
              "type": "PATTERN",
              "value": "(?:0o(?:_*[0-7](?:_*[0-7])*_*(?:\\._*[0-7](?:_*[0-7])*_*)?|_*\\._*[0-7](?:_*[0-7])*_*))"
            },
            {
              "type": "PATTERN",
              "value": "(?:0d(?:_*[0-9AaBb](?:_*[0-9AaBb])*_*(?:\\._*[0-9AaBb](?:_*[0-9AaBb])*_*)?|_*\\._*[0-9AaBb](?:_*[0-9AaBb])*_*))"
            },
            {
              "type": "PATTERN",
              "value": "(?:0x(?:_*[0-9A-Fa-f](?:_*[0-9A-Fa-f])*_*(?:\\._*[0-9A-Fa-f](?:_*[0-9A-Fa-f])*_*)?|_*\\._*[0-9A-Fa-f](?:_*[0-9A-Fa-f])*_*)(?:p[+-]?(?:_*[0-9](?:_*[0-9])*_*|0b_*[01](?:_*[01])*_*|0s_*[0-5](?:_*[0-5])*_*|0o_*[0-7](?:_*[0-7])*_*|0d_*[0-9AaBb](?:_*[0-9AaBb])*_*|0x_*[0-9A-Fa-f](?:_*[0-9A-Fa-f])*_*))?)"
            },
            {
              "type": "PATTERN",
              "value": "(?:_*[0-9](?:_*[0-9])*_*[^\\s+\\-]*|0[bsoxd][^\\s+\\-]*|(?:_*\\._*[0-9][^\\s+\\-]*))"
            }
          ]
        }

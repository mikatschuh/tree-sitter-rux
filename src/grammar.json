        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[iu](?:_*[0-9](?:_*[0-9])*_*|0b_*[01](?:_*[01])*_*|0s_*[0-5](?:_*[0-5])*_*|0o_*[0-7](?:_*[0-7])*_*|0d_*[0-9AaBb](?:_*[0-9AaBb])*_*|0x_*[0-9A-Fa-f](?:_*[0-9A-Fa-f])*_*)"
